### Project ignores
tmp/
# The pinned fabro binary is fetched into the orchestrator-image build context
# at build time (orchestrator-image/build-and-verify.sh copies it from
# ~/.fabro/bin/fabro) — a 111MB blob, never committed. The version is pinned in
# orchestrator-image/Dockerfile's FABRO_VERSION.
orchestrator-image/fabro
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/
.codex
.idea/

### Python toolchain artifacts
__pycache__/
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
.ruff_cache/
.pyright/
.mutmut-cache/
mutants/
htmlcov/

### UV local state
.venv/
livespec_orchestrator_beads_fabro.egg-info/

### Beads / Dolt substrate
# Per-clone bd runtime state (Dolt working copy, lockfiles, runtime
# artifacts, the per-machine metadata.json) is excluded by
# .beads/.gitignore (bd-managed, itself TRACKED). Only
# .beads/config.yaml (the server-mode tenant connection pointer — no
# per-machine project_id, no password) and .beads/.gitignore are
# committed, matching the family-wide per-repo tenant cutover policy.
.beads-credential-key
secrets.env.local
*.env.local
