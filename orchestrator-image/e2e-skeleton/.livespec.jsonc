// Minimal livespec config for the W7 live-golden-master throwaway skeleton.
// connection.fake=false selects the ShellBeadsClient so the dispatcher reads
// this repo's EMBEDDED .beads/ ledger (bd init without --server). The server
// host/port/user stay irrelevant under embedded mode (the per-command bd argv
// carries NO connection flags — bd reads .beads/config.yaml), BUT
// connection.prefix IS required: the store-config loader (_config.py
// _require_prefix) demands it as bd's issue-ID create-prefix, and it MUST match
// the `bd init --prefix` the golden-master uses (acceptance-live-golden-master.sh).
{
  "template": "livespec",
  "spec_root": "SPECIFICATION",
  // The UNMODIFIED production prepare chain runs
  // `livespec_dev_tooling.checks.plugin_resolution`, which fleet-wide (since M6)
  // REQUIRES a top-level `harnesses` declaration. This throwaway greeting
  // skeleton has no interactive `/livespec:*` command surface of its own — it is
  // exercised only as a factory-dispatch target — so both runtimes are declared
  // `exempt` (which the verifier PASSes with no smoke run), not `supported`.
  "harnesses": {
    "claude": { "status": "exempt", "reason": "W7 golden-master throwaway greeting skeleton — no interactive /livespec:* surface; exercised only as a factory-dispatch target." },
    "codex":  { "status": "exempt", "reason": "W7 golden-master throwaway greeting skeleton — no interactive /livespec:* surface; exercised only as a factory-dispatch target." }
  },
  "implementation": { "plugin": "livespec-orchestrator-beads-fabro" },
  "livespec-orchestrator-beads-fabro": {
    "format": "beads",
    "connection": { "fake": false, "prefix": "e2egreet" }
  }
}
