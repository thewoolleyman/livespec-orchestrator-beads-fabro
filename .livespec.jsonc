// Project-local livespec configuration for livespec-orchestrator-beads-fabro.
// This plugin dogfoods livespec: the SPECIFICATION/ tree at the repo
// root is the live spec; this plugin's own impl tracking lives in a
// per-repo beads TENANT DATABASE on the shared dolt-server (NOT in JSONL
// files at the repo root — that is the plaintext sibling's substrate).
//
// Authority:
//   livespec/SPECIFICATION/contracts.md
//     §"Cross-repo coordination — pin-and-bump"
//     §"`compat` block" (the schema this file populates)
//   dev-tooling/implementation/research/beads-schema-mapping.md
//     §2.1 (the verified v1.0.5 server-mode FLAGS connection model)
{
  "template": "livespec",
  "spec_root": "SPECIFICATION",
  "implementation": { "plugin": "livespec-orchestrator-beads-fabro" },
  // Fleet-default credential-injection wrapper (argv-form command prefix). The
  // bin/*.py credential self-heal (bin/_bootstrap.py) re-execs the process
  // through this prefix when BEADS_DOLT_PASSWORD is absent, so the 1Password
  // Environment wrapper injects the shared fleet tenant secret before any beads
  // CLI runs. Backend-agnostic per livespec core's config schema (a non-empty
  // array of strings); the secret backend + injected vars are this project's
  // own concern and are NEVER committed here.
  "credential_wrapper": ["/usr/local/bin/with-livespec-env.sh", "--"],
  "harnesses": {
    "claude": { "status": "supported", "canonical_command": "livespec-orchestrator-beads-fabro:next" },
    "codex":  { "status": "supported", "canonical_command": "livespec-orchestrator-beads-fabro:next" }
  },
  "livespec-orchestrator-beads-fabro": {
    // Substrate marker. The plaintext sibling declares "jsonl"; this
    // plugin's substrate is a beads/Dolt tenant DB.
    "format": "beads",
    "compat": {
      // semver range and pinned tag against livespec. The pinned value
      // is a placeholder until the first livespec release tag; the next
      // bump-pin PR will set a real release tag here. Doctor's
      // contract-version-compatibility invariant fires `warn` against
      // "master" pins; that is expected during bootstrap.
      "livespec": ">=0.1.0,<1.0.0",
      "pinned": "v0.6.4"
    },
    // Per-repo beads tenant CONNECTION block. These keys are read by
    // commands/_config.py and overlaid by the LIVESPEC_BD_PATH /
    // LIVESPEC_BEADS_FAKE environment variables. The tenant PASSWORD is
    // deliberately ABSENT — it is supplied only via the BEADS_DOLT_PASSWORD
    // environment variable at bd-call time and is NEVER committed here.
    //
    // `tenant` == `database` == `server_user` is the load-bearing tenant
    // identity (one Dolt name serves all three). It is the ABBREVIATED
    // `livespec-orch-beads-fabro` (25 chars), NOT the repo/plugin/package name
    // `livespec-orchestrator-beads-fabro` (33 chars): Dolt/MySQL caps SQL
    // usernames at 32, so the 33-char name cannot be the tenant.
    // The issue-ID `prefix` is DECOUPLED from the tenant DB name: it is the
    // short, readable `bd-ib` (bd's server-stored create-prefix), matching the
    // git-jsonl sibling's `bd-gj`. Existing items keep their historical
    // `livespec-impl-beads-*` IDs; new items get `bd-ib-*`. TCP-only (no
    // `socket` key): the dolt socket dir is 0750 dolt:dolt and
    // untraversable by sandboxed callers, matching the family-wide
    // server-mode connection model.
    //
    // `fake` selects the hermetic in-memory backend (the default CI tier
    // and the no-live-connection runtime fallback). It is false here so the
    // committed config describes the real connection; CI and tests set
    // LIVESPEC_BEADS_FAKE=1 to force the fake.
    "connection": {
      "tenant": "livespec-orch-beads-fabro",
      "prefix": "bd-ib",
      "database": "livespec-orch-beads-fabro",
      "server_user": "livespec-orch-beads-fabro",
      "server_host": "127.0.0.1",
      "server_port": 3307,
      "fake": false
    }
  },
  // The three orchestrator-side contract CLIs, named in argv form per
  // livespec/SPECIFICATION/contracts.md §"Orchestrator CLI contract — the
  // three named CLIs" and §"CLI shape conventions" (one binary per side
  // with subcommands). Paths are project-root-relative; callability is
  // verified by the `config-named-cli-callability` doctor invariant.
  "orchestrator": {
    "name": "livespec-orchestrator-beads-fabro",
    "spec_reader": ["python3", ".claude-plugin/scripts/bin/orchestrator.py", "spec-reader"],
    "gap_capture": ["python3", ".claude-plugin/scripts/bin/orchestrator.py", "gap-capture"],
    "drift_capture": ["python3", ".claude-plugin/scripts/bin/orchestrator.py", "drift-capture"]
  }
}
