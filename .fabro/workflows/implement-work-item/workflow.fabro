// implement-work-item — the family-discipline phase graph.
//
// This is the Fabro Loop half of the Beads/Dolt + Fabro reference
// orchestrator (livespec spec.md §"Contract + reference implementations
// architecture"). One run consumes ONE ready work-item and produces one
// merged-or-failed implementation attempt:
//
//   implement (Red-Green-Replay) -> janitor hard gate (`mise exec --
//   just check`, fix loop bounded at 3 visits) -> PR + rebase
//   auto-merge arming.
//
// The run executes in an ISOLATED Fabro-owned docker sandbox clone
// (Architecture C, workflow.toml): Fabro clones the repo fresh inside
// the sandbox and checks out a managed run branch before the first node
// runs — the graph never creates worktrees and never touches the host.
// The per-item brief (work-item id, title, description, publish branch)
// arrives via the run goal (`--goal-file`), rendered into the prompts
// as {{ goal }}.
//
// Agent nodes use the ACP backend: the Claude Code adapter reads
// CLAUDE_CODE_OAUTH_TOKEN from the sandbox environment, injected at
// dispatch time via the Dispatcher's uncommitted run-config overlay
// (see workflow.toml §"CREDENTIAL CHANNEL"). Per
// docs.fabro.sh/core-concepts/agents §"ACP backend", ACP requires a
// local or Docker sandbox (the Dispatcher runs the docker provider).
digraph ImplementWorkItem {
    graph [
        goal="Implement one ready work-item per the livespec family discipline"
        default_max_retries=0
        stall_timeout="7200s"
    ]

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    implement [
        label="Implement (Red-Green-Replay)"
        backend="acp"
        acp.command="npx -y @agentclientprotocol/claude-agent-acp"
        timeout="7200s"
        goal_gate=true
        prompt="@prompts/implement.md"
    ]

    // Janitor hard gate: a non-zero `just check` MUST prevent the PR
    // stage (livespec non-functional-requirements.md §"Orchestrator-
    // internal Dispatcher guidance"). Script outcome routes the edges:
    // exit 0 -> succeeded -> pr; non-zero -> failed -> fix loop.
    janitor [
        label="Janitor: just check"
        shape=parallelogram
        timeout="3600s"
        script="mise exec -- just check"
    ]

    fix [
        label="Fix janitor failures"
        backend="acp"
        acp.command="npx -y @agentclientprotocol/claude-agent-acp"
        timeout="3600s"
        max_visits=3
        prompt="@prompts/fix.md"
    ]

    pr [
        label="Open PR + arm rebase auto-merge"
        backend="acp"
        acp.command="npx -y @agentclientprotocol/claude-agent-acp"
        timeout="1800s"
        goal_gate=true
        prompt="@prompts/pr.md"
    ]

    // Conditional edges take priority over the unconditional fallback,
    // so exit 0 routes Green; every other outcome falls back to Red.
    start -> implement -> janitor
    janitor -> pr  [label="Green", condition="outcome=succeeded"]
    janitor -> fix [label="Red"]
    fix -> janitor
    pr -> exit
}
